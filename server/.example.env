# Create .env file and copy all the contents of this file into .env file and fill the values *, 
# except in the MONGODB_URI replace username and password with your actual mongodb username and password.
# Do not change the variable names.

NODE_ENV=development
# NODE_ENV=production

# CORS_ORIGIN=*
CORS_ORIGIN=http://localhost:5173

PORT=5000

# Database       mongodb username password  
MONGODB_URI=mongodb+srv://<username>:<password>@<clustername>.qwggt.mongodb.net/CodeAtlas?appName=Cluster0


# JWT 
# Secret keys for JWT tokens
JWT_ACCESS_TOKEN_SECRET= add access token
JWT_REFRESH_TOKEN_SECRET= add refresh token

# Expiration times for JWT tokens and cookies
JWT_ACCESS_TOKEN_AND_COOKIE_EXPIRES_IN=1d
JWT_REFRESH_TOKEN_AND_COOKIE_EXPIRES_IN=30d

# Cookie settings (should match the tokens)
ACCESS_AND_REFRESH_TOKEN_COOKIE_SAME_SITE=lax